# ──────────────────────────────────────────────────────────────
# Lethus — Root Environment Variables
# Used by docker-compose.yml for production deployment.
# Copy to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────

# OpenAI / LLM API keys
OPENAI_API_KEY=sk-your-key-here
UPSTREAM_LLM_URL=https://api.openai.com/v1/chat/completions
UPSTREAM_LLM_KEY=sk-your-key-here

# Frontend — the URL where the backend is reachable from the browser
NEXT_PUBLIC_API_URL=https://your-backend-domain.example.com

# ── Optional (have defaults) ─────────────────────────────────

# PostgreSQL credentials (defaults shown)
POSTGRES_USER=lethus
POSTGRES_PASSWORD=lethus_password
POSTGRES_DB=lethus_db

# CORS — "*" for all origins, or comma-separated list
CORS_ORIGINS=*
