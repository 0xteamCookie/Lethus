DATABASE_URL=postgresql://lethus:lethus_password@postgres:5432/lethus_db?schema=public

# Upstream — single OpenAI-compatible API (base URL, no trailing slash)
UPSTREAM_URL=https://api.openai.com/v1
UPSTREAM_KEY=sk-your-key-here

# Models
UPSTREAM_CHAT_MODEL=gpt-4o-mini
UPSTREAM_EMBED_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
# ── Optional (defaults shown) ────────────────────────────────

# Milvus — gRPC address (inside docker: milvus:19530)
# MILVUS_ADDRESS=milvus:19530

# Server
# PORT=8000
# CORS_ORIGINS=*

# Milvus collection name
# MILVUS_COLLECTION=turn_embeddings

# Algorithm tuning
# COLD_START_THRESHOLD=5
# RETRIEVAL_TOKEN_BUDGET=2000
# RECENT_TURNS_COUNT=3
# STATE_DOC_UPDATE_INTERVAL=3
# KADANE_THETA=1.0
# GAIN_SHIFT=0.6
# CHANGELOG_BOOST=1.0
# CHANGELOG_NEIGHBOR_BOOST=0.3

# LLM response limits
# MAX_RESPONSE_TOKENS=800

# ╔═══════════════════════════════════════════════════════════╗
# ║  FRONTEND                                                 ║
# ╚═══════════════════════════════════════════════════════════╝

# Backend API URL (as seen from the browser)
NEXT_PUBLIC_API_URL=https://your-backend-domain.example.com

# ╔═══════════════════════════════════════════════════════════╗
# ║  INFRASTRUCTURE (docker-compose)                          ║
# ╚═══════════════════════════════════════════════════════════╝

# PostgreSQL container credentials
# Must match user/password/db in DATABASE_URL above.
POSTGRES_USER=lethus
POSTGRES_PASSWORD=lethus_password
POSTGRES_DB=lethus_db

# MinIO (Milvus object storage)
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
