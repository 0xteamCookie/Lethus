# ──────────────────────────────────────────────────────────────
# Lethus Backend — Environment Variables
# Copy to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────

# PostgreSQL — connection string for Prisma
# For local dev with docker-compose.dev.yml: localhost:5432
# Inside docker compose (production): postgres:5432
DATABASE_URL="postgresql://lethus:lethus_password@localhost:5432/lethus_db?schema=public"

# OpenAI — used for embeddings and cold path LLM calls
OPENAI_API_KEY=sk-your-key-here

# Upstream LLM — where user-facing chat requests get forwarded
UPSTREAM_LLM_URL=https://api.openai.com/v1/chat/completions
UPSTREAM_LLM_KEY=sk-your-key-here

# ── Optional (have sensible defaults) ────────────────────────

# Milvus — gRPC address
# Local dev: localhost:19530 | Docker compose: milvus:19530
MILVUS_ADDRESS=localhost:19530

# Server
PORT=8000

# CORS — "*" for all origins, or comma-separated list
CORS_ORIGINS=http://localhost:3000

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Milvus collection name
MILVUS_COLLECTION=turn_embeddings

# ── Algorithm Tuning ─────────────────────────────────────────

COLD_START_THRESHOLD=5
RETRIEVAL_TOKEN_BUDGET=2000
RECENT_TURNS_COUNT=3
STATE_DOC_UPDATE_INTERVAL=3
KADANE_THETA=1.0
GAIN_SHIFT=0.6
CHANGELOG_BOOST=1.0
CHANGELOG_NEIGHBOR_BOOST=0.3

# ── Docker Compose / Infrastructure ─────────────────────────
# Used by docker-compose.yml for postgres container.
# Must match the user/password/db in DATABASE_URL above.

POSTGRES_USER=lethus
POSTGRES_PASSWORD=lethus_password
POSTGRES_DB=lethus_db
