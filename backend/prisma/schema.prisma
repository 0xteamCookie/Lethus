generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  turns            Turn[]
  changelogEntries ChangelogEntry[]
  stateDoc         StateDoc?

  @@map("conversations")
}

model Turn {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  turnNumber     Int      @map("turn_number")
  role           String
  content        String   @db.Text
  tokenCount     Int      @map("token_count")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, turnNumber, role])
  @@index([conversationId, turnNumber])
  @@map("turns")
}

model ChangelogEntry {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  turnNumber     Int      @map("turn_number")
  category       String
  content        String   @db.Text
  supersededBy   Int?     @map("superseded_by")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, category])
  @@index([conversationId, supersededBy])
  @@map("changelog_entries")
}

model StateDoc {
  id                String   @id @default(uuid())
  conversationId    String   @unique @map("conversation_id")
  content           String   @db.Text
  version           Int      @default(1)
  lastUpdatedAtTurn Int      @default(0) @map("last_updated_at_turn")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("state_docs")
}
