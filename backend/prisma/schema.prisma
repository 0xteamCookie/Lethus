generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Conversation {
  id        String   @id @default(uuid())
  browserId String?  @map("browser_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  turns            Turn[]
  changelogEntries ChangelogEntry[]

  @@index([browserId])
  @@map("conversations")
}

model Turn {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  turnNumber     Int      @map("turn_number")
  role           String
  content        String   @db.Text
  tokenCount     Int      @map("token_count")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, turnNumber, role])
  @@index([conversationId, turnNumber])
  @@map("turns")
}

model ChangelogEntry {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  turnNumber     Int      @map("turn_number")
  category       String
  content        String   @db.Text
  supersededBy   Int?     @map("superseded_by")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, category])
  @@index([conversationId, supersededBy])
  @@map("changelog_entries")
}
